{
  "expo": {
    "name": "Truecloud Sync",
    "slug": "truecloud-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "scheme": "truecloudsync",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truecloud.sync",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Truecloud Sync needs access to your photos to back them up to your server.",
        "NSPhotoLibraryAddUsageDescription": "Truecloud Sync needs access to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptative-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.truecloud.sync",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ]
    },
    "platforms": ["ios", "android"],
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Truecloud Sync needs access to your photos to back them up.",
          "savePhotosPermission": "Truecloud Sync needs access to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-router",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": ["image/*", "video/*"],
          "androidMultiIntentFilters": ["image/*", "video/*"],
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 100,
            "NSExtensionActivationSupportsMovieWithMaxCount": 100
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8e50aa50-9f1f-499b-8240-f7ff9e7dfd20"
      }
    }
  }
}

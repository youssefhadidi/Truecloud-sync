{
  "expo": {
    "name": "Truecloud Sync",
    "slug": "truecloud-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "truecloudsync",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truecloud.sync",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Truecloud Sync needs access to your photos to back them up to your server.",
        "NSPhotoLibraryAddUsageDescription": "Truecloud Sync needs access to your photo library."
      }
    },
    "android": {
      "package": "com.truecloud.sync",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ]
    },
    "platforms": ["ios", "android"],
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Truecloud Sync needs access to your photos to back them up.",
          "savePhotosPermission": "Truecloud Sync needs access to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
